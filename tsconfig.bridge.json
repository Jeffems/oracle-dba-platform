{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "strict": false,
    "resolveJsonModule": true,
    "outDir": "dist-bridge",
    "rootDir": ".",
    "noEmit": false,
    "types": ["node"]
  },
  "include": [
    "backend/node/oracle-bridge.ts",
    "src/types/oracle.ts"
  ]
}
