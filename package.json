{
  "name": "oracle-dba-tauri-react",
  "version": "3.1.1",
  "private": true,
  "description": "Oracle DBA Desktop profissional",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm run build:app",
    "preview": "vite preview",
    "tauri": "node ./node_modules/@tauri-apps/cli/tauri.js",
    "tauri:dev": "npm run build:bridge && npm run tauri -- dev",
    "tauri:build": "npm run build:bridge && npm run tauri -- build",
    "oracle:bridge": "tsx backend/node/oracle-bridge.ts",
    "build:frontend": "npm run build",
    "build:portable": "npm run build:bridge && tauri build && npm run assemble:portable",
    "build:release": "npm run tauri:build",
    "bridge:dev": "npm run oracle:bridge",
    "build:bridge": "node scripts/build-oracle-bridge.cjs",
    "build:app": "node ./node_modules/typescript/bin/tsc && node ./node_modules/vite/bin/vite.js build",
    "assemble:portable": "node scripts/assemble-portable.cjs",
    "build:installer": "npm run tauri:build",
    "api:central": "node central-api/server.cjs",
    "dashboard:web": "npm --prefix dashboard-web run dev",
    "dashboard:build": "npm --prefix dashboard-web run build",
    "platform:dev": "npm run db:generate && node scripts/start-platform-dev.cjs",
    "db:generate": "prisma generate --schema central-api/prisma/schema.prisma",
    "db:migrate": "prisma migrate dev --schema central-api/prisma/schema.prisma --name init_v2_6_0",
    "db:deploy": "prisma migrate deploy --schema central-api/prisma/schema.prisma",
    "db:studio": "prisma studio --schema central-api/prisma/schema.prisma",
    "agent:rust:build": "cargo build --release --manifest-path agent-rust/Cargo.toml",
    "agent:rust:run": "cd agent-rust && cargo run -- --console --config config.json",
    "agent:rust:install": "powershell -ExecutionPolicy Bypass -File agent-rust/scripts/install-service.ps1",
    "agent:rust:uninstall": "powershell -ExecutionPolicy Bypass -File agent-rust/scripts/uninstall-service.ps1",
    "agent:rust:package": "powershell -ExecutionPolicy Bypass -File agent-rust/scripts/package-agent.ps1"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "@tauri-apps/api": "^2.2.0",
    "@tauri-apps/plugin-shell": "^2.2.0",
    "@tanstack/react-query": "^5.62.0",
    "clsx": "^2.1.1",
    "lucide-react": "^0.468.0",
    "oracledb": "^6.7.0",
    "tailwind-merge": "^2.5.5",
    "zustand": "^5.0.2",
    "@prisma/client": "^6.9.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.2.0",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^6.0.3",
    "prisma": "^6.9.0"
  }
}
